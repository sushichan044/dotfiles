          "url": "https://mcp.grep.app",
        },
        "notion": {
          "type": "http",
          "url": "https://mcp.notion.com/mcp",
        },
        "sentry": {
          "type": "http",
          "url": "https://mcp.sentry.dev/mcp",
        },
      },
      "preferredNotifChannel": "terminal_bell",
      "shiftEnterKeyBindingInstalled": true,
      "theme": "dark",
    },
  },
  "claude_desktop": {
    "settings": {
      "globalShortcut": "",
      "mcpServers": {},
    },
  },
  "codex": {
    "config": {
      "approval_policy": "on-request",
      "features": {
        "collaboration_modes": true,
        "steer": true,
        "codex_hooks": true,
      },
      "mcp_servers": {
        "bundlephobia": {
          "url": "https://bundlephobia-mcp.sushichan044.workers.dev/mcp",
        },
        "context7": {
          "url": "https://mcp.context7.com/mcp",
        },
        "deepwiki": {
          "url": "https://mcp.deepwiki.com/mcp",
        },
        "grep": {
          "url": "https://mcp.grep.app",
        },
        "notion": {
          "url": "https://mcp.notion.com/mcp",
        },
        "sentry": {
          "type": "http",
          "url": "https://mcp.sentry.dev/mcp",
        },
      },
      "model_reasoning_effort": "medium",
      "plan_mode_reasoning_effort": "xhigh",
      "notify": ["/Users/sushichan044/.codex/sushichan044/scripts/notify_mac.sh"],
      "sandbox_mode": "danger-full-access",
      "shell_environment_policy": {
        "inherit": "all",
        "set": {
          // https://github.com/unjs/std-env/blob/2b364bdb44d7e56e0fe2070758dd42fec55c6144/src/agents.ts#L70-L90
          "AI_AGENT": "codex",
        },
      },
      "sandbox_workspace_write": {
        "network_access": true,
      },
      "web_search": "live",
      "tui": {
        "status_line": [
          "model-with-reasoning",
          "context-remaining",
          "project-root",
          "git-branch",
          "five-hour-limit",
        ],
      },
    },
  },
  "cursor": {
