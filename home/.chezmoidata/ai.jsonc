{
  "claude": {
    "settings": {
      "checkpointingEnabled": true,
      "installMethod": "unknown",
      "mcpServers": {
        "aws-knowledge": {
          "type": "http",
          "url": "https://knowledge-mcp.global.api.aws",
        },
        "bundlephobia": {
          "type": "http",
