git_protocol: ssh
editor: vim
prompt: enabled
pager:
http_unix_socket:
browser:
version: "1"
aliases:
    st: status
    # PR
    p: pr
    pc: pr create -w
    pco: pr checkout
    pv: pr view -w
    # Repo
    r: repo
    rc: repo create
    rv: repo view -w
    rf: repo fork
    rs: repo sync
    ownername: repo view --json owner,name --jq '.owner.login+"/"+.name'
    # { "owner": "sushichan044", "repo": "dotfiles", "url": "https://github.com/sushichan044/dotfiles/pull/1", "branch": "fix/aaa" , "number": 1 }
    resolve-pr: "pr view --json number,url,headRefName,headRepositoryOwner,headRepository --jq '{owner: .headRepositoryOwner.login, repo: .headRepository.name, url: .url, branch: .headRefName, number: .number}'"
    # browse
    b: browse
    bs: browse --settings
    br: browse --repo
{{ if eq .ostype "windows" "wsl" }}
    # Copy Repo Url
    cpr: '!gh repo view --json url --jq ".url" | clip.exe && echo "✅ Copied GitHub Repo URL to clipboard"'
{{ else if eq .ostype "darwin" }}
    # Copy Repo Url
    cpr: '!gh repo view --json url --jq ".url" | pbcopy && echo "✅ Copied GitHub Repo URL to clipboard"'
{{ end }}
