# frozen_string_literal: true

# tap
## https://docs.brew.sh/Brew-Bundle-and-Brewfile#trusted
tap "artginzburg/tap", trusted: {
  formulae: ["sudo-touchid"],
}
tap "buo/cask-upgrade", trusted: true
tap "kayac/tap", trusted: {
  formulae: ["ecspresso"],
}

# from custom tap
brew "kayac/tap/ecspresso", trusted: true

if OS.mac?
  brew "artginzburg/tap/sudo-touchid",
    trusted: true,
    postinstall:
    "echo '⏩ Configuring sudo-touchid... This requires sudo permission.' && sudo ${HOMEBREW_PREFIX}/bin/brew services restart artginzburg/tap/sudo-touchid"
end

