# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

source "$HOME/.zsh.d/setup/init.zsh"

# source command override technique
# https://zenn.dev/fuzmare/articles/zsh-source-zcompile-all
function source {
  # do not compile if starts with /dev/fd
  if [[ "$1" == /dev/fd/* ]]; then
    builtin source "$@"
    return
  fi

  ensure_zcompiled $1
  builtin source $1
}
function ensure_zcompiled {
  local compiled="$1.zwc"
  if [[ ! -r "$compiled" || "$1" -nt "$compiled" ]]; then
    echo "\033[1;36mCompiling\033[m $1"
    zcompile $1
  fi
}
ensure_zcompiled ~/.zshrc

# https://zenn.dev/fuzmare/articles/zsh-plugin-manager-cache
# Cache sheldon script
sheldon_config_dir="$XDG_CONFIG_HOME/sheldon"
sheldon_cache="$sheldon_config_dir/cache.zsh"
sheldon_toml="$sheldon_config_dir/plugins.toml"
if [[ ! -r "$sheldon_cache" || "$sheldon_toml" -nt "$sheldon_cache" ]]; then
  sheldon source > "$sheldon_cache"
fi
source "$sheldon_cache"
unset sheldon_config_dir sheldon_cache sheldon_toml

# prepare completions
COMPLETION_HOME="$HOME/.zsh.d/completions"
fpath=("$COMPLETION_HOME" "${fpath[@]}")
autoload -Uz compinit && compinit

# Only make targets appear in `make` completions
zstyle ':completion:*:*:make:*' tag-order 'targets'

# To customize prompt, run `p10k configure` or edit dot_zsh.d/autoload/eager/p10k.zsh.
source "$HOME/.zsh.d/autoload/eager/p10k.zsh"
zsh-defer load_zsh_files_from_dir "$HOME/.zsh.d/autoload/lazy"

# Auto suggestion text color
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=242'

if command_exists mise; then
  cached_eval "mise activate zsh"
  zsh-defer cached_eval "mise completion zsh"
fi

if command_exists rg; then
  export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/.ripgreprc"
fi

# Terraform plugin cache
# https://developer.hashicorp.com/terraform/cli/config/config-file#provider-plugin-cache
export TF_PLUGIN_CACHE_DIR="$XDG_CACHE_HOME/terraform/plugin-cache"

if command_exists git-wt; then
  zsh-defer cached_eval "git-wt --init zsh"
fi

{{ if not .for_personal }}
{{/* Load Private zshrc */}}
{{- (onepasswordDetailsFields "2pybemjhmpdlmbog3ssdgom5uq").notesPlain.value -}}
{{ end }}


# Dynamic Shell Completions
if command_exists fzf; then
  zsh-defer cached_eval "fzf --zsh"
fi

if command_exists uv; then
  zsh-defer cached_eval "uv generate-shell-completion zsh"
fi

if command_exists uvx; then
  zsh-defer cached_eval "uvx --generate-shell-completion zsh"
fi

if command_exists sidetable; then
  zsh-defer cached_eval "sidetable completion zsh"
fi

if command_exists pitchfork; then
  zsh-defer cached_eval "pitchfork completion zsh"
fi

if command_exists op; then
  zsh-defer cached_eval "op completion zsh"
fi

if command_exists pnpm; then
  zsh-defer cached_eval "pnpm completion zsh"
fi

GCLOUD_BASE="$BREW_BASE/share/google-cloud-sdk"
if dir_exists "$GCLOUD_BASE"; then
  _setup_gcloud() {
    if file_exists "$GCLOUD_BASE/path.zsh.inc"; then
      source "$GCLOUD_BASE/path.zsh.inc"
    fi
    if file_exists "$GCLOUD_BASE/completion.zsh.inc"; then
      source "$GCLOUD_BASE/completion.zsh.inc"
    fi
    unfunction _setup_gcloud
  }
  zsh-defer _setup_gcloud
fi

_setup_gh_token() {
  if command_exists gh && gh auth status &>/dev/null; then
    GH_TOKEN="$(gh auth token)"
    if command_exists mise; then
      export MISE_GITHUB_TOKEN="$GH_TOKEN"
    fi
  fi
  unfunction _setup_gh_token
}
zsh-defer _setup_gh_token

zsh-defer unfunction source

# Expand alias with space and enter
_simple_abbreviation() {
  zle _expand_alias
  zle self-insert
}
_simple_abbreviation_accept_line() {
  zle _expand_alias
  zle accept-line
}
zle -N _simple_abbreviation
bindkey ' ' _simple_abbreviation
zle -N _simple_abbreviation_accept_line
bindkey '^M' _simple_abbreviation_accept_line
