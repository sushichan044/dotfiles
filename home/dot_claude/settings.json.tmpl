{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login",
  "env": {
    {{/* https://github.com/unjs/std-env/blob/2b364bdb44d7e56e0fe2070758dd42fec55c6144/src/agents.ts#L70-L90 */ -}}
    "AI_AGENT": "claude",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "0",
    "FORCE_AUTOUPDATE_PLUGINS": "1",
    "FORCE_AUTO_BACKGROUND_TASKS": "1"
  },
  "showThinkingSummaries":true,
  "useAutoModeDuringPlan": {{ if eq .for_personal false }}true{{ else }}false{{ end }},
  "model": {{ if eq .for_personal false }}"opusplan"{{ else }}"sonnet"{{ end }}{{ if eq .for_personal false }},
  "effortLevel": "high"{{ end }},
  "cleanupPeriodDays": 99999,
  "statusLine": {
    "type": "command",
    "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/statusline.ts"
  },
  "language": "Japanese",
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/UserPromptSubmit/question.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/worktree_root.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/polish.ts"
          }
        ]
      }
    ],
    "SubAgentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/polish.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs -I {} seil post-edit {} --reporter claude"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PostToolUse/superpowers/worktree.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PostToolUse/post_rebase_and_pr_creation.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PostToolUse/post_write_pr.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PostToolUse/post_push_pr_maintenance.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PostToolUse/post_commit.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/inject_timestamp.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/dump_plan.ts"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/web_fetch_advice.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/markdown_tree.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/worktree_root.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/typescript/no_restricted_edit.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/worktree_root.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/worktree_root.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/check_gh_api.ts"
          },
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/inject_timestamp.ts"
          }
        ]
      },
      {
        "matcher": "mcp__deepwiki__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/PreToolUse/check_github_repo_visibility.ts"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/worktree_root.ts"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/git-wt.ts"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run --silent -i {{ .chezmoi.workingTree }}/.claude/hooks/git-wt.ts"
          }
        ]
      }
    ]
  },
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": {{ if eq .for_personal false }}"auto"{{ else }}"acceptEdits"{{ end }},
    "allow": [
      "Edit",
      "Write",
      "NotebookEdit",
      "WebSearch",

      "Bash(git:*)",

      "Bash(gh cache:*)",
      "Bash(gh extension browse:*)",
      "Bash(gh extension list:*)",
      "Bash(gh extension search:*)",
      "Bash(gh gist list:*)",
      "Bash(gh gist view:*)",

      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",

      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",

      "Bash(gh release list:*)",
      "Bash(gh release view:*)",

      "Bash(gh repo gitignore:*)",
      "Bash(gh repo license:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo sync:*)",
      "Bash(gh repo view:*)",

      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run download:*)",

      "Bash(gh search:*)",

      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",

      "Bash(gh sub-issue:*)",

      "Bash(mise install:*)",
      "Bash(mise run:*)",

      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(awk:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",

      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",

      "Bash(man:*)",
      "Bash(which:*)",
      "Bash(type:*)",

      "Bash(fd:*)",
      "Bash(rg:*)",

      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(na:*)",
      "Bash(ni:*)",

      "Bash(bundle:*)",

      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go mod:*)",
      "Bash(go get:*)",
      "Bash(go list:*)",
      "Bash(go test:*)",
      "Bash(go tool pprof:*)",
      "Bash(go vet:*)",
      "Bash(go version:*)",

      "Bash(semgrep scan:*)",

      "Skill(codex-review)",
      "Bash(codex review:*)",

      "Skill(playwright-cli)",
      "Bash(playwright-cli:*)",

      "Skill(prepare-issue-pr)",
      "Skill(polish)",

      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__bundlephobia__get_npm_package_info",
      "mcp__deepwiki__read_wiki_structure",
      "mcp__deepwiki__read_wiki_contents",
      "mcp__deepwiki__ask_question",
      "mcp__ide__getDiagnostics",
      "mcp__notion__notion-fetch",
      "mcp__grep__searchGitHub",
      "mcp__sentry__get_issue_details",
      "mcp__sentry__find_projects",
      "mcp__sentry__search_issues",
      "mcp__sentry__search_events",
      "mcp__sentry__search_docs",
      "mcp__sentry__get_doc",

      "Bash(aws cloudfront describe-function:*)",
      "Bash(aws s3api get-bucket-public-access-block:*)",
      "Bash(aws s3api get-public-access-block:*)",
      "Bash(aws cloudfront get-origin-access-control:*)"
    ],
    "deny": [
      "Bash(sudo:*)",

      "Read(.env*)",
      "Read(.env.*)",
      "Read(.dev.vars)",
      "Read(.dev.vars.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",

      "Bash(curl:*)",
      "Bash(http:*)",
      "Bash(wget:*)",

      "Bash(nc:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",

      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",

      "Bash(go mod vendor:*)",

      "Bash(semgrep ci:*)",
      "Bash(semgrep login:*)"
    ]
  }
}
