# This file should be sourced from .zshenv and .zprofile
source "$HOME/.zsh.d/setup/init.zsh"

add_to_path_if_not_exists "$HOME/.local/bin"
add_to_path_if_not_exists /opt/local/bin
add_to_path_if_not_exists /usr/local/bin
add_to_path_if_not_exists /usr/bin
add_to_path_if_not_exists /bin
add_to_path_if_not_exists /usr/sbin
add_to_path_if_not_exists /sbin

export LANG=ja_JP.UTF-8
export LC_ALL=ja_JP.UTF-8

{{ if eq .chezmoi.os "darwin" -}}
export BREW_BASE="/opt/homebrew"

COURSIER_BIN_DIR="$HOME/Library/Application Support/Coursier/bin"
{{ else if eq .chezmoi.os "linux" -}}
export BREW_BASE="/home/linuxbrew/.linuxbrew"

COURSIER_BIN_DIR="$HOME/.local/share/coursier/bin"
{{ end -}}
export BREW_BIN="${BREW_BASE}/bin/brew"

# Load homebrew (cached to avoid fork on every shell startup)
if file_exists "$BREW_BIN"; then
    cached_eval "$BREW_BIN shellenv"
fi

# Use GNU utils as default on macOS
if is_mac; then
    add_to_path_if_not_exists "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin"
    add_to_manpath_if_not_exists "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnuman"

    add_to_path_if_not_exists "$HOMEBREW_PREFIX/opt/findutils/libexec/gnubin"
    add_to_manpath_if_not_exists "$HOMEBREW_PREFIX/opt/findutils/libexec/gnuman"

    add_to_path_if_not_exists "$HOMEBREW_PREFIX/opt/gawk/libexec/gnubin"
    add_to_manpath_if_not_exists "$HOMEBREW_PREFIX/opt/gawk/libexec/gnuman"

    add_to_path_if_not_exists "$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin"
    add_to_manpath_if_not_exists "$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnuman"

    add_to_path_if_not_exists "$HOMEBREW_PREFIX/opt/grep/libexec/gnubin"
    add_to_manpath_if_not_exists "$HOMEBREW_PREFIX/opt/grep/libexec/gnuman"
fi

# Load Scala coursier
if dir_exists "$COURSIER_BIN_DIR"; then
    add_to_path_if_not_exists "$COURSIER_BIN_DIR"
fi

# Load Rust
if dir_exists "$HOME/.cargo/bin"; then
    add_to_path_if_not_exists "$HOME/.cargo/bin"
fi

# Set ghq root directory
export GHQ_ROOT="$HOME/workspace"

# Load chezmoi managed bin
if dir_exists "$HOME/.chezmoi-bin"; then
    add_to_path_if_not_exists "$HOME/.chezmoi-bin"
fi

if dir_exists "$HOME/.sushichan044/bin"; then
    add_to_path_if_not_exists "$HOME/.sushichan044/bin"
fi

# Jetbrains Scripts
if is_mac; then
    add_to_path_if_not_exists "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
fi

# Load mise shims
if command_exists mise; then
    export MISE_RUBY_DEFAULT_PACKAGES_FILE="$XDG_CONFIG_HOME/mise/.default-gems"
    eval "$(mise activate zsh --shims)"
fi

########## Additional Configurations ##########

if command_exists rg; then
    export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/.ripgreprc"
fi

# Terraform plugin cache
# https://developer.hashicorp.com/terraform/cli/config/config-file#provider-plugin-cache
mkdir -p "$XDG_CACHE_HOME/terraform/plugin-cache"
export TF_PLUGIN_CACHE_DIR="$XDG_CACHE_HOME/terraform/plugin-cache"

# https://semgrep.dev/docs/metrics#automatic-collection-opt-in-and-opt-out
export SEMGREP_SEND_METRICS="off"
