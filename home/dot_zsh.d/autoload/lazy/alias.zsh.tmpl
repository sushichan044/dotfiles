alias mkdir='mkdir -p'

alias reitou='tar -zcvf'
alias kaitou='tar -xvf'

alias rrr="exec $SHELL -l"

alias g='git'
alias gs='git status'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias gpl='git pull'
alias grm='git rm'
alias grt='cd "$(git repo-root)"'
alias lg='lazygit'
alias gg='ghq get'
alias genignore='gh repo gitignore'
alias genlicense='gh repo license'

alias br='brew'
alias bru='brew update && brew bundle install --file="$HOME/.Brewfile"'
alias bri='brew install'

alias d='docker'
alias dc='docker compose'
alias dcb='docker compose build'
alias dcu='docker compose up -d'
alias dcd='docker compose down'

# mise
alias m='mise'
alias mi='mise install'
alias mr='mise run'
alias mw='mise watch'
alias mp='mise prepare'

# latex
alias tl='sudo tlmgr'
alias tlu='sudo tlmgr update --self && sudo tlmgr update --all'

# misc
alias cv='code .'
alias cw='code *.code-workspace(.N[1])'
alias crv='cursor .'
alias crw='cursor *.code-workspace(.N[1])'
alias rv='rubymine .'
alias zv='zed .'
alias xv='xed .'

alias c='claude'
alias oc='opencode'

alias cz='chezmoi'

if command_exists eza; then
    alias ls='eza --group-directories-first'
    alias ll='eza -abghHliS --git --time-style=iso --group-directories-first'
else
    if is_mac; then
        alias ls='ls -G'
        alias ll='ls -l -G'
    else
        alias ls='ls --color=always'
        alias ll='ls -l --color=always'
    fi
fi

if is_linux && command_exists apt; then
    alias agi='sudo apt install'
    alias agu='sudo apt update && sudo apt upgrade'
    alias agc='sudo apt autoremove -y && sudo apt autoclean -y'
    alias agr='sudo apt remove'
fi

alias dft='difit --include-untracked'
alias dfp='difit --pr'

alias za='zellij attach'

{{ if eq .ostype "wsl" }}
# wsl-open
alias open='wsl-open'
# ssh
alias ssh='ssh.exe'
alias ssh-add='ssh-add.exe'
{{ end }}
